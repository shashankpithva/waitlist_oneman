# ── Resend waitlist configuration ──
# Get your API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Create an audience, then copy its ID: https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: a verified sender for the confirmation email.
# Must be on a domain you've verified in Resend (https://resend.com/domains).
# If left unset, signups are still saved — the welcome email is just skipped.
RESEND_FROM_EMAIL="Oneman <hello@yourdomain.com>"
